<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <IsPackable>true</IsPackable>
    <PackageId>Cvent.SDK</PackageId>
    <Version>1.0.1</Version>
    <TargetFramework>net8.0</TargetFramework>
    <Authors>Cvent</Authors>
    <Copyright>Copyright (c) Cvent 2025</Copyright>
    <PackageTags>Cvent</PackageTags>
    <PackageProjectUrl>https://developers.cvent.com/docs</PackageProjectUrl>
    <Description>Developer-friendly &amp; type-safe C# SDK for the Cvent API Platform (REST/JSON over HTTPS).<br/>
<br/>
Documentation: https://developers.cvent.com/docs<br/>
Quickstart: https://developers.cvent.com/docs/rest-api/tutorials/developer-quickstart<br/>
API standards: https://developers.cvent.com/docs/rest-api/reference/api-standards<br/>
<br/>
Authentication (OAuth2):<br/>
- Client credentials flow is supported for server-to-server integrations.<br/>
- Authorization code flow is supported only for planner users with the administrator role (developer users cannot use auth code flow).<br/>
<br/>
Endpoints:<br/>
- North America: https://api-platform.cvent.com<br/>
- Europe: https://api-platform-eur.cvent.com<br/>
- Version: ea<br/>
<br/>
Rate limits:<br/>
Cvent APIs enforce tier-based rate limits to ensure platform stability. If you exceed the limit, the API returns 429 Too Many Requests. Apply retry/backoff and follow the guidance in the rate limit docs.<br/>
<br/>
Pagination (cursor-based):<br/>
Some endpoints return a paginated response. The SDK exposes a Next method to retrieve the next page using the cursor; when Next returns null, there are no more pages.<br/>
<br/>
Example:<br/>
var res = await sdk.Users.GetAccountUserGroupsAsync(req);<br/>
while (res != null) { res = await res.Next!(); }<br/>
<br/>
Filtering:<br/>
Many list endpoints support filter expressions. Example: filter=lastName eq &apos;Smith&apos; (use double quotes when the value contains a single quote).<br/>
<br/>
Versioning:<br/>
Expect backward-compatible changes to add new optional fields and parameters. Breaking changes are delivered via new API versions with deprecation periods for older versions.<br/>
    </Description>
  </PropertyGroup>

  <PropertyGroup>
    <Nullable>enable</Nullable>
    <NoWarn>1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE.txt</PackageLicenseFile>
  </PropertyGroup>

  <ItemGroup>
    <None Include="..\..\..\NUGET.md" Pack="true" PackagePath="README.md"/>
    <None Include="..\..\..\LICENSE.txt" Pack="true" PackagePath="\"/>
    <None Include="..\..\..\docs\**\*" Pack="true" PackagePath="\docs"  CopyToOutputDirectory="PreserveNewest"/>
  </ItemGroup>

  <PropertyGroup>
    <DebugSymbols>true</DebugSymbols>
    <DebugType>portable</DebugType>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>

  <PropertyGroup Condition="'$(GITHUB_ACTIONS)' == 'true'">
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <EmbedAllSources>true</EmbedAllSources>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="newtonsoft.json" Version="13.0.3" />
    <PackageReference Include="nodatime" Version="3.1.9" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="8.0.0" PrivateAssets="All"/>
  </ItemGroup>

</Project>